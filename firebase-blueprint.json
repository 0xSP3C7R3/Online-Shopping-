{
  "entities": {
    "User": {
      "title": "User",
      "description": "User profile inside the store",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "email": { "type": "string" },
        "name": { "type": "string" },
        "role": { "type": "string", "enum": ["admin", "user"] },
        "avatar": { "type": "string" },
        "phone": { "type": "string" },
        "address": { "type": "string" },
        "joinedDate": { "type": "string" },
        "password": { "type": "string" }
      },
      "required": ["id", "email", "name", "role", "avatar", "phone", "address", "joinedDate"]
    },
    "Product": {
      "title": "Product",
      "description": "E-commerce product details",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "description": { "type": "string" },
        "price": { "type": "number" },
        "stock": { "type": "number" },
        "image": { "type": "string" },
        "category": { "type": "string" }
      },
      "required": ["id", "name", "description", "price", "stock", "image", "category"]
    },
    "Order": {
      "title": "Order",
      "description": "Customer purchase order details",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "userId": { "type": "string" },
        "userName": { "type": "string" },
        "items": { "type": "array" },
        "totalAmount": { "type": "number" },
        "status": { "type": "string", "enum": ["Pending", "Delivered", "Cancelled"] },
        "date": { "type": "string" },
        "paymentMethod": { "type": "string" }
      },
      "required": ["id", "userId", "userName", "items", "totalAmount", "status", "date", "paymentMethod"]
    }
  },
  "firestore": {
    "/products/{productId}": {
      "schema": "Product",
      "description": "Collection of available store products"
    },
    "/orders/{orderId}": {
      "schema": "Order",
      "description": "Collection of customer purchase orders"
    },
    "/users/{userId}": {
      "schema": "User",
      "description": "Collection of user account profiles"
    }
  }
}
